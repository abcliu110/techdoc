      "evidenceKinds": ["red-output", "green-output", "state-transition-test", "failure-injection", "focus-test"]
    },
    {
      "key": "queryCapabilities",
      "action": "implement-and-verify",
      "method": "按排序、筛选、分页的顺序逐项完成失败测试、最小实现和组合回归，不并行冻结多个能力。",
      "implements": [
        "/api/features/filtering",
        "/api/features/pagination",
        "/api/features/sorting"
      ],
      "verifies": [
        "/quality/oracles/filterPreservesSelection",
        "/quality/oracles/remoteQueryIsNotAppliedLocally",
        "/quality/oracles/sortProducesSingleIntent"
      ],
      "evidenceKinds": ["red-output", "green-output", "interaction-test", "event-count-test", "combination-test"]
    },
    {
      "key": "selectionCapability",
      "action": "implement-and-verify",
      "method": "在查询能力回归保持通过的前提下增加选择失败夹具，覆盖排序、筛选和翻页后的身份保持，再实现最小选择切片。",
      "implements": [
        "/api/events/rowSelectionChange",
        "/api/features/rowSelection"
      ],
      "verifies": [
        "/quality/oracles/filterPreservesSelection",
        "/quality/oracles/selectionStableAfterSort"
      ],
      "evidenceKinds": ["red-output", "green-output", "interaction-test", "combination-test"]
    },
    {
      "key": "geometryCapabilities",
      "action": "implement-and-verify",
      "method": "先固定几何夹具和像素比较方法，再分别接入固定列与列宽能力，并在每次改变后重跑滚动组合测试。",
      "implements": [
        "/api/features/columnPinning",
        "/api/features/columnSizing",
        "/view/layout",
        "/view/regions",
        "/view/regions/body",
        "/view/regions/header"
