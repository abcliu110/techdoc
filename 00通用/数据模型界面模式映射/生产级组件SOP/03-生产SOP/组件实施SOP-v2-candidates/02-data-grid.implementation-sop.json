      ],
      "evidenceKinds": ["red-output", "green-output", "unit-test", "contract-error-test"]
    },
    {
      "key": "asyncRecovery",
      "action": "implement-and-verify",
      "method": "依次为状态转换、迟到结果、失败保留和重试建立失败注入；每个切片通过后才进入下一个切片。",
      "implements": [
        "/api/actions/retryQuery",
        "/api/events/queryChange",
