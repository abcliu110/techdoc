      "implements": [
        "/compatibility/v1Authority",
        "/risk/upgradeTriggers"
      ],
      "verifies": [],
      "evidenceKinds": ["repository-binding", "source-revision", "command-manifest"]
    },
    {
      "key": "identityCore",
      "action": "implement-and-verify",
      "method": "先建立行列身份和重复身份的失败夹具，确认失败原因后实现最小核心，再运行相关回归。",
      "implements": [
        "/api/props/columns",
        "/api/props/getRowId",
        "/behavior/identity/column",
