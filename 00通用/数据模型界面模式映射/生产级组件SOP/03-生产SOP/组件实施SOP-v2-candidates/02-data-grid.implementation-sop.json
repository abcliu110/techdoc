        "/quality/visualOracles/scrollReachability"
      ],
      "evidenceKinds": ["red-output", "green-output", "geometry-assertion", "viewport-screenshot", "scroll-test"]
    },
    {
      "key": "responsiveStates",
      "action": "implement-and-verify",
      "method": "以规范声明的视口、相邻宽度、内容和主题夹具形成状态矩阵；逐格验证后保存截图和可达性记录。",
