{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/implementation-sop.schema.json",
  "type": "object",
  "required": ["sopVersion", "componentKey", "status", "approval", "specification", "steps"],
  "properties": {
    "sopVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "componentKey": { "type": "string", "pattern": "^[0-9]{2}:[a-z0-9-]+$" },
    "status": { "enum": ["Draft", "ReviewReady", "Approved", "Stale"] },
    "approval": {
      "type": "object",
      "required": ["status", "authors", "requiredRoles", "records"],
      "properties": {
        "status": { "enum": ["pending", "approved"] },
        "authors": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "requiredRoles": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "records": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": ["role", "reviewer", "approvedAt", "sopVersion", "sopDigest", "specificationVersion", "specificationDigest"],
            "properties": {
              "role": { "type": "string", "minLength": 1 },
              "reviewer": { "type": "string", "minLength": 1 },
              "approvedAt": { "type": "string", "minLength": 1 },
              "sopVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
              "sopDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
              "specificationVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
              "specificationDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "specification": {
      "type": "object",
      "required": ["path", "version", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "action", "method", "implements", "verifies", "evidenceKinds"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]+$" },
          "action": { "enum": ["bind", "implement-and-verify", "measure", "review", "package"] },
          "method": { "type": "string", "minLength": 1 },
          "implements": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^/" } },
          "verifies": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^/" } },
          "evidenceKinds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
