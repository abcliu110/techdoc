{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/component-spec.schema.json",
  "x-supported-keywords": [
    "type",
    "required",
    "properties",
    "additionalProperties",
    "items",
    "minItems",
    "uniqueItems",
    "enum",
    "const",
    "pattern",
    "minLength",
    "minimum",
    "allOf",
    "$ref"
  ],
  "type": "object",
  "required": [
    "schemaVersion",
    "specificationVersion",
    "component",
    "lifecycle",
    "scope",
    "api",
    "behavior",
    "view",
    "accessibility",
    "quality",
    "security",
    "compatibility",
    "risk",
    "decisions",
    "approval"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "specificationVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "component": { "type": "object" },
    "lifecycle": { "type": "object" },
    "scope": { "type": "object" },
    "api": { "type": "object" },
    "behavior": { "type": "object" },
    "view": { "type": "object" },
    "accessibility": { "type": "object" },
    "quality": { "type": "object" },
    "security": { "type": "object" },
    "compatibility": { "type": "object" },
    "risk": { "type": "object" },
    "decisions": { "type": "array", "items": { "type": "object" } },
    "approval": { "type": "object" }
  },
  "additionalProperties": false
}
