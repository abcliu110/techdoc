{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nms://component/editable-grid/v1",
  "type": "object",
  "required": ["schemaVersion", "specificationVersion", "component", "lifecycle", "scope", "api", "behavior", "accessibility", "quality", "approval"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "specificationVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "component": {
      "type": "object",
      "required": ["key", "name", "englishName", "packageSubpath", "implementationType"],
      "properties": {
        "key": { "const": "02:editable-grid" },
        "name": { "type": "string", "minLength": 1 },
        "englishName": { "const": "EditableGrid" },
        "packageSubpath": { "const": "@nms/ui/editable-grid" },
        "implementationType": { "const": "derived-component" }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["specificationStatus", "implementationAllowed", "apiStatus", "approvalStatus"],
      "properties": {
        "specificationStatus": { "enum": ["Draft", "ReviewReady", "Approved", "Stale"] },
        "implementationAllowed": { "type": "boolean" },
        "apiStatus": { "enum": ["proposed", "approved", "stable"] },
        "approvalStatus": { "enum": ["pending", "approved"] }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["purpose", "in", "out"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "in": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "out": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "api": {
      "type": "object",
      "required": ["rows", "columns", "identity", "columnConstruction", "versionSemantics", "editing", "commit", "commitState", "commitOwnership", "defaultBehavior"],
      "properties": {
        "rows": { "type": "string", "minLength": 1 },
        "columns": { "type": "string", "minLength": 1 },
        "identity": { "type": "string", "minLength": 1 },
        "columnConstruction": { "type": "string", "minLength": 1 },
        "versionSemantics": { "type": "string", "minLength": 1 },
        "editing": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "commitState": { "type": "string", "minLength": 1 },
        "commitOwnership": { "type": "string", "minLength": 1 },
        "defaultBehavior": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "behavior": {
      "type": "object",
      "required": ["start", "draft", "baseline", "validation", "cancelCell", "discardAll", "commit", "failure", "retry", "accepted", "stale", "scopeReconciliation", "query"],
      "properties": {
        "start": { "type": "string", "minLength": 1 },
        "draft": { "type": "string", "minLength": 1 },
        "baseline": { "type": "string", "minLength": 1 },
        "validation": { "type": "string", "minLength": 1 },
        "cancelCell": { "type": "string", "minLength": 1 },
        "discardAll": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "failure": { "type": "string", "minLength": 1 },
        "retry": { "type": "string", "minLength": 1 },
        "accepted": { "type": "string", "minLength": 1 },
        "stale": { "type": "string", "minLength": 1 },
        "scopeReconciliation": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "accessibility": {
      "type": "object",
      "required": ["grid", "input", "commands", "errors", "announcements"],
      "properties": {
        "grid": { "type": "string", "minLength": 1 },
        "input": { "type": "string", "minLength": 1 },
        "commands": { "type": "string", "minLength": 1 },
        "errors": { "type": "string", "minLength": 1 },
        "announcements": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "required": ["oracles", "budgets"],
      "properties": {
        "oracles": {
          "type": "object",
          "required": ["stableCellDraft", "invalidCommitBlocked", "singleCommitWhileSubmitting", "failureRetainsDraft", "staleResultIgnored", "acceptedRequiresNewSnapshot", "rowVersionFreezesAtFirstDraft", "retryCreatesNewCommitIdentity", "scopeExitDropsOrphanDraft", "escapeCancelsOneCell", "readOnlyColumnsStayReadOnly"],
          "properties": {
            "stableCellDraft": { "type": "string", "minLength": 1 },
            "invalidCommitBlocked": { "type": "string", "minLength": 1 },
            "singleCommitWhileSubmitting": { "type": "string", "minLength": 1 },
            "failureRetainsDraft": { "type": "string", "minLength": 1 },
            "staleResultIgnored": { "type": "string", "minLength": 1 },
            "acceptedRequiresNewSnapshot": { "type": "string", "minLength": 1 },
            "rowVersionFreezesAtFirstDraft": { "type": "string", "minLength": 1 },
            "retryCreatesNewCommitIdentity": { "type": "string", "minLength": 1 },
            "scopeExitDropsOrphanDraft": { "type": "string", "minLength": 1 },
            "escapeCancelsOneCell": { "type": "string", "minLength": 1 },
            "readOnlyColumnsStayReadOnly": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "budgets": {
          "type": "object",
          "required": ["commandP95MaximumMs", "longTaskMaximumMs", "packageGzipMaximumBytes"],
          "properties": {
            "commandP95MaximumMs": { "type": "number", "minimum": 1 },
            "longTaskMaximumMs": { "type": "number", "minimum": 1 },
            "packageGzipMaximumBytes": { "type": "number", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": ["status", "authors", "requiredRoles", "records"],
      "properties": {
        "status": { "enum": ["pending", "approved"] },
        "authors": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "requiredRoles": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "records": { "type": "array", "uniqueItems": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
